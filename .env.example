# API
PORT=3000
DATABASE_URL=postgresql://lmpdf:lmpdf@localhost:5432/lmpdf
REDIS_URL=redis://localhost:6379
VISION_URL=http://localhost:8001

# S3 Storage (Garage)
S3_ENDPOINT=http://localhost:3900
S3_REGION=garage
S3_FORCE_PATH_STYLE=true
GARAGE_ACCESS_KEY=GKxxxxxxxxxxxxx
GARAGE_SECRET_KEY=xxxxxxxxxxxxxxx
S3_BUCKET=lmpdf

# Auth
API_TOKEN=
JWT_SECRET=change-me-in-prod
ALLOW_SELF_REGISTER=false
AUTH_MODE=local
AUTH_ALLOW_LOCAL_ADMIN_FALLBACK=true
AUTH_AUTO_PROVISION_USERS=true

# MFA TOTP encryption (AES-256-GCM) — 64 hex chars = 32 bytes
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Si non défini, les secrets TOTP sont stockés en clair (rétrocompatible)
MFA_ENCRYPTION_KEY=

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:4173,http://localhost:5173
STRICT_CORS=true

# WEB
VITE_API_URL=http://localhost:3000/api

# Organization
ORGANIZATION_MODE=team
ORGANIZATION_DEFAULT_OWNERSHIP=user
ORGANIZATION_ALLOW_USER_GROUPS=true
ORGANIZATION_ALLOW_SHARED_FOLDERS=true

# LDAP / Active Directory (optional)
LDAP_ENABLED=false
LDAP_URL=ldap://your-dc.domain.local:389
LDAP_BIND_DN=CN=svc-lmpdf,OU=ServiceAccounts,DC=domain,DC=local
LDAP_BIND_PASSWORD=changeme
LDAP_SEARCH_BASE=OU=Users,DC=domain,DC=local
LDAP_SEARCH_FILTER=(sAMAccountName={{username}})
LDAP_ADMIN_GROUP=CN=LMPdf-Admins,OU=Groups,DC=domain,DC=local
LDAP_EDITOR_GROUP=CN=LMPdf-Editors,OU=Groups,DC=domain,DC=local
LDAP_INSECURE_TLS=false
